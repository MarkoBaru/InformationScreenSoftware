# ============================================
# InformationScreen – Umgebungsvariablen
# Kopiere als .env und passe die Werte an
# ============================================

# Datenbank-Anbieter: "Sqlite" oder "MongoDB"
DATABASE_PROVIDER=MongoDB

# --- MongoDB / Cosmos DB MongoDB API ---
# Lokales MongoDB:
MONGODB_CONNECTION=mongodb://mongodb:27017
# Azure Cosmos DB MongoDB API:
# MONGODB_CONNECTION=mongodb://<account>:<key>@<account>.mongo.cosmos.azure.com:10255/?ssl=true&retrywrites=false&maxIdleTimeMS=120000&appName=@<account>@
MONGODB_DATABASE=informationscreen

# --- Azure Blob Storage (optional, sonst lokales Dateisystem) ---
AZURE_BLOB_CONNECTION=
AZURE_BLOB_CONTAINER=media

# --- CORS erlaubte Origins (kommasepariert) ---
ALLOWED_ORIGINS=http://localhost

# --- JWT Authentication ---
# WICHTIG: In Produktion einen sicheren, zufälligen Key verwenden (min. 32 Zeichen)!
JWT_KEY=InfoScreen-Default-SuperSecret-Key-Min32Chars!!
JWT_ISSUER=InformationScreen

# --- App-Port ---
APP_PORT=80
